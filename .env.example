# ============================================
# Andreas Boutsikas Portal - Environment Example
# LOCAL DEVELOPMENT ONLY
# ============================================
#
# Copy to .env for local development:
#   cp .env.example .env
#
# For production deployment use .env.production instead.
# ============================================

# ----------------------------------------
# Database (PostgreSQL) - local dev
# ----------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/andreas_portal"

# ----------------------------------------
# Authentication
# ----------------------------------------
# Weak secret — local dev only, never use in production
NEXTAUTH_SECRET="dev-only-localhost-secret-do-not-use-in-production"

# Local dev URL
NEXTAUTH_URL="http://localhost:3000"

# ----------------------------------------
# Storage
# ----------------------------------------
STORAGE_PATH="/data/andreas-portal"

# ----------------------------------------
# Application
# ----------------------------------------
NODE_ENV="development"
