# ============================================
# Nginx Reverse Proxy Configuration
# Andreas Boutsikas Portal
# ============================================
#
# Usage:
#   1. Copy this file to /etc/nginx/sites-available/abportal
#   2. Symlink: ln -s /etc/nginx/sites-available/abportal /etc/nginx/sites-enabled/
#   3. Update SSL certificate paths
#   4. nginx -t && systemctl reload nginx
#
# For SSL, you can use Let's Encrypt:
#   certbot --nginx -d portal.yourdomain.com
# ============================================

upstream abportal {
    server localhost:3000;
    keepalive 32;
}

server {
    listen 80;
    server_name portal.yourdomain.com;

    # Redirect HTTP to HTTPS
    return 301 https://$server_name$request_uri;
}

server {
    listen 443 ssl http2;
    server_name portal.yourdomain.com;

    # ----------------------------------------
    # SSL Configuration
    # Update these paths for your certificates
    # ----------------------------------------
    ssl_certificate /etc/nginx/ssl/fullchain.pem;
    ssl_certificate_key /etc/nginx/ssl/privkey.pem;

    ssl_session_timeout 1d;
    ssl_session_cache shared:SSL:50m;
    ssl_session_tickets off;

    # Modern SSL configuration
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;

    # HSTS (uncomment if sure)
    # add_header Strict-Transport-Security "max-age=63072000" always;

    # ----------------------------------------
    # Security Headers
    # ----------------------------------------
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # ----------------------------------------
    # Logging
    # ----------------------------------------
    access_log /var/log/nginx/abportal_access.log;
    error_log /var/log/nginx/abportal_error.log;

    # ----------------------------------------
    # Gzip Compression
    # ----------------------------------------
    gzip on;
    gzip_vary on;
    gzip_min_length 1024;
    gzip_proxied any;
    gzip_types text/plain text/css text/xml text/javascript application/javascript application/json application/xml image/svg+xml;

    # ----------------------------------------
    # Request Limits
    # ----------------------------------------
    client_max_body_size 100M;  # For large ZIP uploads
    proxy_read_timeout 600s;
    proxy_send_timeout 600s;
    proxy_connect_timeout 75s;

    # ----------------------------------------
    # Reverse Proxy to Next.js App
    # ----------------------------------------
    location / {
        proxy_pass http://abportal;
        proxy_http_version 1.1;

        # Upgrade WebSocket
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Prevent caching of dynamic content
        proxy_no_cache $cookie_nocache $cookie_authorization;
        proxy_cache_bypass $cookie_nocache $cookie_authorization;
    }

    # ----------------------------------------
    # Static file caching
    # ----------------------------------------
    location /_next/static {
        proxy_pass http://abportal;
        proxy_cache_valid 200 60m;
        add_header Cache-Control "public, immutable";
    }

    # ----------------------------------------
    # Health check endpoint (pass through)
    # ----------------------------------------
    location /api/health {
        proxy_pass http://abportal;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
    }
}
